{
  "manifest_version": 3,
  "name": "高级书签管理器",
  "version": "1.0",
  "description": "一个用于搜索、添加和管理书签的浏览器扩展。",
  "permissions": [
    "bookmarks",
    "activeTab",
    "notifications"
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg"
    },
    "default_title": "我的书签",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "js/background.js"
  }
}